import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        int X = sc.nextInt();   // push-ups per day
        
        int totalPushUps = X * 31;  // January has 31 days
        
        System.out.println(totalPushUps);
        
        sc.close();
    }
}
